{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://rrpxksavfzfjlrjcvayv.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "scenesmith-studio-mcp",
      "version": "0.1.0",
      "title": "SceneSmith Studio"
    },
    "tools": [
      {
        "name": "list_projects",
        "title": "List screenplay projects",
        "description": "List the signed-in user's screenplay projects in SceneSmith Studio. Returns id, title, logline, genre, tone, project_type, status, and updated_at.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max projects to return (default 50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_project",
        "title": "Get screenplay project",
        "description": "Fetch a single screenplay project by id, including title, logline, genre, tone, target length, and project type.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "project_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "The project's UUID (from list_projects)."
            }
          },
          "required": [
            "project_id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_scenes",
        "title": "List scenes in a project",
        "description": "List all scenes for a given screenplay project, in order. Returns id, scene_heading, location, time_of_day, title, status, and order_index.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "project_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "The project's UUID."
            }
          },
          "required": [
            "project_id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_characters",
        "title": "List characters in a project",
        "description": "List characters (name, role, archetype, external goal, internal need, wound) for a screenplay project.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "project_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "The project's UUID."
            }
          },
          "required": [
            "project_id"
          ]
        },
        "outputSchema": null
      }
    ]
  }
