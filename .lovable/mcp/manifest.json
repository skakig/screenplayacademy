      {
        "name": "create_scene",
        "title": "Create a scene",
        "description": "Create a new scene in a screenplay project. Order is appended to the end of the project unless order_index is provided. Respects project RLS — only the project owner can create scenes.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "project_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "The project's UUID."
            },
            "scene_heading": {
              "description": "Slugline, e.g. 'INT. WAREHOUSE - NIGHT'.",
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "title": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "location": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "time_of_day": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "emotional_purpose": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "plot_purpose": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "conflict": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "order_index": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100000
            },
            "initial_blocks": {
              "description": "Optional initial screenplay blocks written into the new scene (max 50).",
              "maxItems": 50,
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "block_type": {
                    "type": "string",
                    "enum": [
                      "scene_heading",
                      "action",
                      "character",
                      "dialogue",
                      "parenthetical",
                      "transition",
                      "shot",
                      "note"
                    ]
                  },
                  "content": {
                    "type": "string"
                  }
                },
                "required": [
                  "block_type",
                  "content"
                ]
              }
            }
          },
          "required": [
            "project_id"
          ]
        },
        "outputSchema": null
      },
